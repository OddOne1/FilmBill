# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=filmbill
POSTGRES_USER=filmbill
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_SECRET

# ── Microsoft 365 SMTP ────────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=billing@yourcompany.com
SMTP_PASS=YOUR_M365_APP_PASSWORD
SMTP_FROM=billing@yourcompany.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=http://localhost
HTTP_PORT=80

# Company branding (shown on invoices / emails)
COMPANY_NAME=Your Production Company
COMPANY_ADDRESS=123 Studio Lane, Los Angeles, CA 90001
COMPANY_PHONE=+1 (310) 000-0000
COMPANY_EMAIL=billing@yourcompany.com
COMPANY_WEBSITE=https://yourcompany.com
COMPANY_VAT=
